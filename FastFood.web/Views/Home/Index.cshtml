@model IEnumerable<FastFood.Models.Item>

@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1>🍔 Welcome to FastFood!</h1>
        <p class="mt-3">Delicious Food Delivered Fresh & Fast!</p>
        <p>🍕 Pizza &nbsp;|&nbsp; 🍔 Burgers &nbsp;|&nbsp; 🥪 Sandwiches &nbsp;|&nbsp; 🍟 Fries</p>
        <a href="#menu" class="btn btn-light btn-lg mt-3 rounded-pill fw-bold">
            🛒 Order Now
        </a>
    </div>
</div>

<!-- Menu Section -->
<div class="container mt-5" id="menu">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color:#ff6b35;">🍽️ Our Delicious Menu</h2>
        <p class="text-muted">Fresh ingredients, amazing taste!</p>
        <hr style="border: 2px solid #ff6b35; width: 100px; margin: auto;" />
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <!-- Default image category k hisaab sy -->
            string defaultImage = "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=400";

            @if (item.Title.ToLower().Contains("pizza"))
            {
                defaultImage = "https://images.unsplash.com/photo-1513104890138-7c749659a591?w=400";
            }
            else if (item.Title.ToLower().Contains("burger"))
            {
                defaultImage = "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=400";
            }
            else if (item.Title.ToLower().Contains("fries") || item.Title.ToLower().Contains("fry"))
            {
                defaultImage = "https://images.unsplash.com/photo-1573080496219-bb080dd4f877?w=400";
            }
            else if (item.Title.ToLower().Contains("sandwich"))
            {
                defaultImage = "https://images.unsplash.com/photo-1528735602780-2552fd46c7af?w=400";
            }
            else if (item.Title.ToLower().Contains("drink") || item.Title.ToLower().Contains("cola"))
            {
                defaultImage = "https://images.unsplash.com/photo-1622483767028-3f66f32aef97?w=400";
            }
            else if (item.Title.ToLower().Contains("chicken"))
            {
                defaultImage = "https://images.unsplash.com/photo-1626645738196-c2a7c87a8f58?w=400";
            }
            else if (item.Title.ToLower().Contains("shawarma"))
            {
                defaultImage = "https://images.unsplash.com/photo-1529006557810-274b9b2fc783?w=400";
            }

            <div class="col-md-4 mb-4">
                <div class="card food-card">
                    @if (item.Image != null)
                    {
                        <img src="@item.Image" alt="@item.Title" />
                    }
                    else
                    {
                        <img src="@defaultImage" alt="@item.Title" />
                    }
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="card-text text-muted small">@item.Description</p>
                        <p class="card-text text-muted small">
                            📁 @item.Category.Name — @item.SubCategory.Name
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="price-badge">@item.Price.ToString("c")</span>
                            <a asp-controller="Cart" asp-action="Add"
                               asp-route-itemId="@item.Id"
                               class="btn btn-order">
                                🛒 Add To Cart
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Features Section -->
<div style="background: linear-gradient(135deg, #ff6b35, #f7931e); color:white;"
     class="mt-5 py-5">
    <div class="container text-center">
        <div class="row">
            <div class="col-md-4 mb-3">
                <h1>🚀</h1>
                <h5 class="fw-bold">Fast Delivery</h5>
                <p>Get your food delivered in minutes!</p>
            </div>
            <div class="col-md-4 mb-3">
                <h1>🍽️</h1>
                <h5 class="fw-bold">Fresh Food</h5>
                <p>Always fresh, always delicious!</p>
            </div>
            <div class="col-md-4 mb-3">
                <h1>💰</h1>
                <h5 class="fw-bold">Best Prices</h5>
                <p>Quality food at affordable prices!</p>
            </div>
        </div>
    </div>
</div>