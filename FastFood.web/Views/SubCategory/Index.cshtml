@model IEnumerable<FastFood.Models.SubCategory>

@{
    ViewData["Title"] = "Sub Categories";
}

<div class="container">
    <div class="row">
        <div class="col-6">
            <h2 class="text-primary">SubCategory List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                Add New SubCategory
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sub in Model)
            {
                <tr>
                    <td>@sub.Name</td>
                    <td>@sub.Category.Name</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@sub.Id"
                           class="btn btn-success btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@sub.Id"
                           class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>