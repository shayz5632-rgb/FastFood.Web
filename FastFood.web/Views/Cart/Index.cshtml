@model IEnumerable<FastFood.Models.Cart>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container">
    <h2 class="text-primary">Shopping Cart</h2>
    <hr />

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Image</th>
                <th>Item</th>
                <th>Price</th>
                <th>Count</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cart in Model)
            {
                <tr>
                    <td>
                        @if (cart.Item.Image != null)
                        {
                            <img src="@cart.Item.Image"
                                 width="50" height="50" />
                        }
                    </td>
                    <td>@cart.Item.Title</td>
                    <td>@cart.Item.Price.ToString("c")</td>
                    <td>
                        <a asp-action="Minus" asp-route-cartId="@cart.Id"
                           class="btn btn-sm btn-warning">-</a>
                        @cart.Count
                        <a asp-action="Add" asp-route-itemId="@cart.ItemId"
                           class="btn btn-sm btn-success">+</a>
                    </td>
                    <td>
                        @((cart.Item.Price * cart.Count).ToString("c"))
                    </td>
                    <td>
                        <a asp-action="Remove" asp-route-cartId="@cart.Id"
                           class="btn btn-danger btn-sm">Remove</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="row">
        <div class="col-12 text-end">
            <h4>Total: @ViewBag.Total.ToString("c")</h4>
            <a asp-controller="Order" asp-action="Index"
               class="btn btn-primary btn-lg">
                Proceed To Order
            </a>
        </div>
    </div>
</div>