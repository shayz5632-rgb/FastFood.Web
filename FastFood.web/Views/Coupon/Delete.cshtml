@model FastFood.Models.Coupon

@{
    ViewData["Title"] = "Delete Coupon";
}

<div class="container">
    <h2 class="text-danger">Delete Coupon</h2>
    <hr />

    <p>Are you sure you want to delete this coupon?</p>

    <div>
        <h4>@Model.Name</h4>
        <p>Type: @Model.CouponType</p>
        <p>Discount: @Model.Discount</p>
        <p>Minimum Amount: @Model.MinimumAmount</p>
        <p>Is Active: @Model.IsActive</p>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>