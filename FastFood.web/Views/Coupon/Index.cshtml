@model IEnumerable<FastFood.Models.Coupon>

@{
    ViewData["Title"] = "Coupons";
}

<div class="container">
    <div class="row">
        <div class="col-6">
            <h2 class="text-primary">Coupon List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                Add New Coupon
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Coupon Type</th>
                <th>Discount</th>
                <th>Minimum Amount</th>
                <th>Is Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var coupon in Model)
            {
                <tr>
                    <td>@coupon.Name</td>
                    <td>@coupon.CouponType</td>
                    <td>@coupon.Discount</td>
                    <td>@coupon.MinimumAmount</td>
                    <td>@coupon.IsActive</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@coupon.Id"
                           class="btn btn-success btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@coupon.Id"
                           class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>